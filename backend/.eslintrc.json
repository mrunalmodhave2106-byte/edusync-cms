{
  "env": {
    "node":  true,
    "jest":  true,
    "es2021":true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^(next|err)" }],
    "no-console":     "off",
    "eqeqeq":         "error",
    "no-var":         "error",
    "prefer-const":   "warn"
  }
}
